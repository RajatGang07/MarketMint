# Copy to backend/.env and fill in. Never commit the real .env.

# --- HTTP -------------------------------------------------------------------
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgres://paper:paper@localhost:5432/paper_trading?sslmode=disable

# --- Groww credentials ------------------------------------------------------
# Preferred: API key + secret. The server mints a fresh access token itself and
# refreshes it when the old one expires (Groww tokens die at 06:00 IST daily).
GROWW_API_KEY=
GROWW_API_SECRET=

# Alternative: paste a pre-generated access token instead. It is used as-is and
# never refreshed, so it stops working the next morning.
GROWW_ACCESS_TOKEN=

GROWW_BASE_URL=https://api.groww.in/v1

# --- Market data ------------------------------------------------------------
# Ordered fallback chain. The first source that answers a call wins; a failing
# one is skipped for two minutes, then re-probed, so a subscription switched on
# later is picked up without a restart.
#
#   groww  real broker feed — needs a Live Data subscription on the account.
#          Without it every /live-data and /historical call answers 403.
#   yahoo  public NSE/BSE prices and history. No key, no subscription.
#   mock   deterministic simulator. Never fails; keep it last as the safety net.
#
# Drop "mock" if you would rather the API error than quietly simulate.
MARKET_DATA_PROVIDERS=groww,yahoo,mock

# --- Instrument universe ----------------------------------------------------
# Groww's public instrument master (no auth). Powers symbol search and the
# company names shown in the UI. Cached locally for 12 hours.
INSTRUMENTS_URL=https://growwapi-assets.groww.in/instruments/instrument.csv
# INSTRUMENTS_CACHE_DIR=/tmp

# --- Paper account ----------------------------------------------------------
STARTING_CASH=1000000
DEFAULT_ACCOUNT_NAME=default

# How often resting LIMIT orders are re-checked against the market.
MATCH_INTERVAL=5s
