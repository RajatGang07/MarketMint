# ------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real credentials.
# ------------------------------------------------------------------

# --- Database ---
# docker-compose uses host "db"; for a local Postgres use "localhost".
DATABASE_URL=postgresql+asyncpg://paper:paper@localhost:5432/paper_trading

# --- Groww API credentials (paste your ROTATED keys here) ---
# The "API key" Groww gives you for the Access Token flow is the access token.
GROWW_ACCESS_TOKEN=
GROWW_API_SECRET=

# --- Market data mode ---
#   true  = simulated prices. No Groww calls. Works offline / outside market hours.
#   false = live Groww market data (requires a valid GROWW_ACCESS_TOKEN).
USE_MOCK_MARKET_DATA=true

# --- Paper account ---
STARTING_CASH=1000000
DEFAULT_ACCOUNT_NAME=default

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
